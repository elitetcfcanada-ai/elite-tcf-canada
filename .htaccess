Options -Indexes

RewriteEngine On

# HTTPS obligatoire en production uniquement.
# En local (XAMPP), forcer HTTPS provoque ERR_CERT_AUTHORITY_INVALID.
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost([:][0-9]+)?$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1([:][0-9]+)?$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

<IfModule mod_php.c>
php_value upload_max_filesize 64M
php_value post_max_size 64M
php_value max_execution_time 300
php_value memory_limit 256M
</IfModule>

<IfModule mod_php7.c>
php_value upload_max_filesize 64M
php_value post_max_size 64M
php_value max_execution_time 300
php_value memory_limit 256M
</IfModule>

<IfModule mod_php8.c>
php_value upload_max_filesize 64M
php_value post_max_size 64M
php_value max_execution_time 300
php_value memory_limit 256M
</IfModule>

# Lecture vidéo : types MIME + streaming (Range) pour HTML5
<IfModule mod_mime.c>
    AddType video/mp4 .mp4 .m4v
    AddType video/webm .webm
    AddType video/ogg .ogv .ogg
    AddType video/quicktime .mov
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(mp4|m4v|webm|ogv|ogg|mov)$">
        Header set Accept-Ranges bytes
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>
